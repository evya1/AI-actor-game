# ---------------------------------------------------------------------------
# actor_t6 — environment template. Copy to .env and fill in ONE LLM backend:
#     cp env.example .env
# .env is git-ignored. The LLM only writes the cosmetic NL move message.
# Full guide: docs/LLM_BACKENDS.md
# ---------------------------------------------------------------------------

# === Actor injection (read by the submodule server) ========================
# Dotted path to our BaseActor subclass:
ACTOR_CLASS=actor_t6.qtable_actor.QTableActor
# Optional trained weights — triggers QTableActor.load(role, path). The cop
# server loads cop_qtable.npy, the thief server loads thief_qtable.npy
# (run_match.py sets the per-role path automatically).
# ACTOR_TABLE=models/cop_qtable.npy

# === MCP inter-server auth (required for a match) ==========================
MCP_API_KEY=change-me
MCP_ALLOWED_API_KEYS=change-me

# === LLM backend — pick ONE of the three blocks below ======================

# --- Option A: Ollama (free, local or VPS; natively supported) -------------
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.2

# --- Option B: OpenRouter (free tier; via scripts/openrouter_adapter.py) ----
# Start the adapter first, then point OLLAMA_BASE_URL at it:
# OLLAMA_BASE_URL=http://localhost:11500
# LLM_MODEL=meta-llama/llama-3.2-3b-instruct:free
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# ADAPTER_PORT=11500

# --- Option C: Anthropic (paid; natively supported) ------------------------
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=claude-opus-4-8
