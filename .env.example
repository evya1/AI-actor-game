# ---------------------------------------------------------------------------
# actor_t6 — environment template. Copy to .env and fill in real values:
#     cp .env.example .env
# .env is git-ignored — NEVER commit real keys. The LLM only writes the
# cosmetic NL move message. Full guide: docs/LLM_BACKENDS.md
# ---------------------------------------------------------------------------

# === MCP inter-server auth (required for a match) ==========================
MCP_API_KEY=change-me
MCP_ALLOWED_API_KEYS=change-me

# === Actor injection (read by the submodule server) ========================
# The server imports a BaseActor subclass at runtime from ACTOR_CLASS, and
# optionally loads weights from ACTOR_TABLE. Set these ONLY in your private
# .env — they are intentionally left blank here so this committed template
# reveals nothing about which actor/strategy we play.
# ACTOR_CLASS=
# ACTOR_TABLE=

# === LLM backend — choose ONE block below (mock values shown) ==============

# --- Option A: Ollama (free; local or AWS/VPS; natively supported) ----------
# OLLAMA_BASE_URL=http://localhost:11434
# LLM_MODEL=llama3.2

# --- Option B: OpenRouter (free tier; via scripts/openrouter_adapter.py) ----
# Start the adapter first, then point OLLAMA_BASE_URL at it:
# OLLAMA_BASE_URL=http://localhost:11500
# LLM_MODEL=meta-llama/llama-3.2-3b-instruct:free
# OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxx
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# ADAPTER_PORT=11500

# --- Option C: Anthropic (paid; natively supported) ------------------------
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# LLM_MODEL=claude-opus-4-8
